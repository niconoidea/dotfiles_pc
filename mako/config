# Gruvbox-like (based on your sway/i3 variables)

# Common
font=monospace 10
padding=10
margin=10
border-size=2
border-radius=0

# Default (normal urgency)
background-color=#282828
text-color=#ebdbb2
border-color=#d79921
progress-color=#d79921

[urgency=low]
# "unfocused-ish"
background-color=#1d2021
text-color=#a89984
border-color=#3c3836
progress-color=#504945

[urgency=critical]
# urgent
background-color=#1d2021
text-color=#ebdbb2
border-color=#cc241d
progress-color=#cc241d
