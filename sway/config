#
# swayidle
#

exec_always swayidle -w \
	timeout 1000 'swaylock -f -c 000000' \
	timeout 1100 'swaymsg "output * dpms off"' \
		resume 'swaymsg "output * dpms on"' \
	before-sleep 'swaylock -f -c 000000'


# Disable idle when any app is fullscreen
for_window [class=".*"] inhibit_idle fullscreen
for_window [app_id=".*"] inhibit_idle fullscreen


exec --no-startup-id env XDG_CURRENT_DESKTOP=sway dbus-update-activation-environment --systemd DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP
gaps inner 6


corner_radius 5
