# ============================================================
# SwayFX Configuration — Nico
# ============================================================

exec paplay /home/nico/.sounds/The\ Microsoft\ Sound.wav

# ── Includes ────────────────────────────────────────────────
include /home/nico/.config/sway/colors/current
include /etc/sway/config-vars.d/*
include /etc/sway/config.d/*
include ~/.config/sway/swaybar.config

# ── Variables ───────────────────────────────────────────────
set $mod        Mod4
set $left       h
set $down       j
set $up         z
set $right      i

set $term       kitty
set $menu       wofi --show drun
set $browser    flatpak run io.github.ungoogled_software.ungoogled_chromium
set $notes      obsidian
set $powermenu  ~/.config/waybar/scripts/powermenu.sh
set $file-mgr   thunar

# ── Font ────────────────────────────────────────────────────
font pango:Roboto 10

# ── Appearance ──────────────────────────────────────────────
default_border  pixel 3
gaps inner      6
corner_radius   5
#default_dim_inactive 0.1

client.focused          $border_color_focused   $background_color_focused \
                        $text_color_focused     $indicator_color \
                        $border_color_focused
client.unfocused        $border_color_unfocused $background_color_unfocused \
                        $text_color_unfocused   $border_color_unfocused \
                        $border_color_unfocused
client.focused_inactive $border_color_inactive  $background_color_unfocused \
                        $text_color_unfocused   $border_color_inactive \
                        $border_color_inactive
client.urgent           $border_color_urgent    $background_color_unfocused \
                        $text_color_unfocused   $border_color_urgent \
                        $border_color_urgent
client.placeholder      $placeholder_color      $background_color_unfocused \
                        $text_color_unfocused   $placeholder_color \
                        $placeholder_color

# ── Input ───────────────────────────────────────────────────
input "type:touchpad" {
    tap                 enabled
    natural_scroll      enabled
    pointer_accel       0.3
    scroll_factor       1.2
}

input "type:keyboard" {
    xkb_layout          de
}

# ── Autostart ───────────────────────────────────────────────
# D-Bus environment — must be first for portals/flatpaks to work
exec dbus-update-activation-environment --systemd \
    DISPLAY WAYLAND_DISPLAY SWAYSOCK XDG_CURRENT_DESKTOP=sway

exec /usr/libexec/xdg-desktop-portal-gtk
exec waybar
exec mako --default-timeout 5000
exec wl-paste --watch cliphist store
exec wlsunset -s 20:00 -S 09:00

exec_always swayidle -w \
    timeout 100000000 'swaylock -f -c 000000'                \
    timeout 110000000 'swaymsg "output * dpms off"'          \
    resume            'swaymsg "output * dpms on"'           \
    before-sleep      'swaylock -f -c 000000'

exec_always autotiling-rs

# ── Key Bindings: Applications ──────────────────────────────
bindsym $mod+Return     exec $term
bindsym $mod+d          exec $menu
bindsym $mod+b          exec $browser
bindsym $mod+o          exec $notes
bindsym $mod+e          exec $file-mgr
bindsym $mod+g          exec steam
bindsym $mod+k          exec kdeconnect-app
bindsym $mod+s          exec signal-desktop
bindsym $mod+m          exec $powermenu

# Clipboard picker
bindsym $mod+c          exec cliphist list | wofi --show dmenu -i | cliphist decode | wl-copy

# Screenshot to clipboard
bindsym $mod+Shift+s exec flameshot gui

# Night light toggle
bindsym $mod+n          exec ~/.config/sway/scripts/toggle_wl_sunset.sh

# Keyboard backlight toggle
bindsym $mod+l          exec sudo ~/.config/sway/scripts/toggle_kbd_backlight.sh

# ── Key Bindings: Window Management ─────────────────────────
# Note: changed from `pkill` (no-op) to sway's native `kill`
bindsym $mod+q          kill
bindsym $mod+f          fullscreen
bindsym $mod+Shift+c    reload
bindsym $mod+Shift+e    exec swaynag -t warning \
                        -m 'Exit sway? This will end your Wayland session.' \
                        -B 'Yes, exit sway' 'swaymsg exit'

bindsym $mod+Shift+space    floating toggle
bindsym $mod+space          focus mode_toggle
bindsym $mod+a              focus parent

floating_modifier $mod normal

# ── Key Bindings: Focus ─────────────────────────────────────
bindsym $mod+$left      focus left
bindsym $mod+$down      focus down
bindsym $mod+$up        focus up
bindsym $mod+$right     focus right
bindsym $mod+Left       focus left
bindsym $mod+Down       focus down
bindsym $mod+Up         focus up
bindsym $mod+Right      focus right

# ── Key Bindings: Move Windows ──────────────────────────────
bindsym $mod+Alt+$left  move left
bindsym $mod+Alt+$down  move down
bindsym $mod+Alt+$up    move up
bindsym $mod+Alt+$right move right
bindsym $mod+Alt+Left   move left
bindsym $mod+Alt+Down   move down
bindsym $mod+Alt+Up     move up
bindsym $mod+Alt+Right  move right

# ── Key Bindings: Workspaces ────────────────────────────────
bindsym $mod+1          workspace number 1
bindsym $mod+2          workspace number 2
bindsym $mod+3          workspace number 3
bindsym $mod+4          workspace number 4
bindsym $mod+5          workspace number 5
bindsym $mod+6          workspace number 6
bindsym $mod+7          workspace number 7
bindsym $mod+8          workspace number 8
bindsym $mod+9          workspace number 9
bindsym $mod+0          workspace number 10

bindsym $mod+Shift+1    move container to workspace number 1
bindsym $mod+Shift+2    move container to workspace number 2
bindsym $mod+Shift+3    move container to workspace number 3
bindsym $mod+Shift+4    move container to workspace number 4
bindsym $mod+Shift+5    move container to workspace number 5
bindsym $mod+Shift+6    move container to workspace number 6
bindsym $mod+Shift+7    move container to workspace number 7
bindsym $mod+Shift+8    move container to workspace number 8
bindsym $mod+Shift+9    move container to workspace number 9
bindsym $mod+Shift+0    move container to workspace number 10

# ── Key Bindings: Layout ────────────────────────────────────
bindsym $mod+Shift+b    splith
bindsym $mod+Shift+v    splitv

# ── Key Bindings: Scratchpad ────────────────────────────────
#bindsym $mod+Shift+minus    move scratchpad
#bindsym $mod+minus          scratchpad show

# ── Key Bindings: Media & Special Keys ──────────────────────
bindsym $mod+Shift+plus     exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym $mod+Shift+minus    exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-

bindsym        XF86AudioRaiseVolume    exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindsym        XF86AudioLowerVolume    exec wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindsym        XF86AudioMute          exec wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
bindsym --locked XF86AudioMicMute     exec pactl set-source-mute @DEFAULT_SOURCE@ toggle
bindsym --locked XF86MonBrightnessUp  exec brightnessctl set 5%+
bindsym --locked XF86MonBrightnessDown exec brightnessctl set 5%-

# ── Resize Mode ─────────────────────────────────────────────
bindsym $mod+r mode "resize"

mode "resize" {
    bindsym $left   resize shrink width  10px
    bindsym $down   resize grow   height 10px
    bindsym $up     resize shrink height 10px
    bindsym $right  resize grow   width  10px
    bindsym Left    resize shrink width  10px
    bindsym Down    resize grow   height 10px
    bindsym Up      resize shrink height 10px
    bindsym Right   resize grow   width  10px

    bindsym Return  mode "default"
    bindsym Escape  mode "default"
}

# ── Window Rules ────────────────────────────────────────────
for_window [class=".*"]  inhibit_idle fullscreen
for_window [app_id=".*"] inhibit_idle fullscreen

# ── Bar ─────────────────────────────────────────────────────
# Managed by exec waybar above.
# Uncomment below to use swaybar with hidden mode instead:
#bar {
#    swaybar_command waybar
#    mode hide
#}
