#!/usr/bin/env bash

temp=$(
  sensors 2>/dev/null | awk '
    /^Tctl:/         {v=$2; gsub(/[+¬įC]/,"",v); print v; exit}
    /^Package id 0:/ {v=$4; gsub(/[+¬įC]/,"",v); print v; exit}
    /^Core 0:/       {v=$3; gsub(/[+¬įC]/,"",v); print v; exit}
  '
)

[ -n "$temp" ] || temp="NA"
echo "ÔčČ ${temp}¬įC"
